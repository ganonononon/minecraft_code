# Discord Bot設定
DISCORD_TOKEN=your_discord_bot_token_here
API_GATEWAY_URL=https://your-api-gateway-url.amazonaws.com/prod
WHITELIST_API_URL=https://your-whitelist-api-url.amazonaws.com/prod

# 死亡通知設定
DEATH_CHANNEL_ID=123456789012345678   # 通知を送るDiscordのチャンネルID
DEATH_WEBHOOK_PORT=8080               # BotがWebhookを受け取るポート番号
DEATH_WEBHOOK_SECRET=your_secret_key  # セキュリティ用の秘密の文字列（何でもOK）
